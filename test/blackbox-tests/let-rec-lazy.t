Test `let rec` with non-function and lazy bindings

  $ . ./setup.sh
  $ cat > dune-project <<EOF
  > (lang dune 3.8)
  > (using melange 0.1)
  > EOF
  $ cat > dune <<EOF
  > (melange.emit
  >  (target out)
  >  (emit_stdlib false)
  >  (preprocess (pps melange.ppx)))
  > EOF
  $ cat > rec_value.ml <<EOF
  > type t = { value : int; next : t Lazy.t }
  > 
  > let rec a = { value = 1; next = b }
  > and b = lazy { value = 2; next = lazy a }
  > 
  > let () =
  >   print_int a.value;
  >   print_char ' ';
  >   print_int (Lazy.force a.next).value;
  >   print_newline ()
  > EOF

Verify valid OCaml with bytecode toplevel

  $ ocaml rec_value.ml
  1 2

Melange build and run

  $ dune build @melange
  $ cat _build/default/out/rec_value.js
  // Generated by Melange
  'use strict';
  
  const Caml_obj = require("melange.js/caml_obj.js");
  const CamlinternalLazy = require("melange/camlinternalLazy.js");
  const Stdlib = require("melange/stdlib.js");
  
  let a = {};
  
  Caml_obj.update_dummy(a, {
    value: 1,
    next: b
  });
  
  const b = {
    LAZY_DONE: false,
    VAL: (function () {
      return {
        value: 2,
        next: {
          LAZY_DONE: true,
          VAL: a
        }
      };
    })
  };
  
  Stdlib.print_int(1);
  
  Stdlib.print_char(/* ' ' */32);
  
  Stdlib.print_int(CamlinternalLazy.force(b).value);
  
  Stdlib.print_newline();
  
  module.exports = {
    a,
    b,
  }
  /*  Not a pure module */
  $ node _build/default/out/rec_value.js 2>&1 | grep -i error
  ReferenceError: Cannot access 'b' before initialization
